*.claude
*.pyc
*.venv
*.pytest_cache
server/.ruff_cache
server/.cache/
server/config.toml
var/*
!var/.gitkeep

# PyInstaller artifacts
clients/desktop/build/
clients/desktop/dist/
clients/desktop/*.spec

# Runtime artifacts
server/errors.log
server/playpalace.db

# Test report coverage files
server/.coverage
server/coverage-report.txt

# Web client local deployment config
clients/web/config.js

# iOS build artifacts (converted from desktop OGGs by scripts/convert-sounds-ios.sh)
clients/macos/PlayPalace/Sources/sounds/
clients/macos/PlayPalace/.build/

# Xcode user-specific state (per-developer, never shared)
**/xcuserdata/
**/*.xcuserstate

# Documents infrastructure (server-local and runtime data)
server/documents/independent/
server/documents/_attribution.json
server/documents/_exports/
